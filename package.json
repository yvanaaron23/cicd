{
  "name": "ci-pipeline-generator",
  "displayName": "Archemist CI/CD Pipeline Generator",
  "description": "Detects your project's stack (Node, Python, Go, Rust, Java, PHP, Ruby, .NET, Docker) and generates a tailored GitHub Actions, GitLab CI, Azure Pipelines, CircleCI, or Bitbucket pipeline — install, lint, test, build, deploy, and release steps wired up automatically.",
  "version": "0.0.1",
  "publisher": "Archemist",
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ci",
    "cd",
    "github actions",
    "gitlab ci",
    "azure pipelines",
    "circleci",
    "bitbucket",
    "pipeline",
    "devops",
    "automation",
    "workflow",
    "monorepo",
    "node",
    "python",
    "go",
    "rust",
    "java",
    "php",
    "ruby",
    "dotnet",
    "docker"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "bin": {
    "generate-pipeline": "./out/cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "ciPipelineGenerator.generate",
        "title": "Generate CI/CD Pipeline",
        "category": "CI/CD Pipeline Generator"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ciPipelineGenerator.generate",
          "when": "explorerResourceIsFolder",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "CI/CD Pipeline Generator",
      "properties": {
        "ciPipelineGenerator.provider": {
          "type": "string",
          "enum": [
            "auto",
            "github",
            "gitlab",
            "azure",
            "circleci",
            "bitbucket"
          ],
          "enumDescriptions": [
            "Detect from existing CI config or the git remote (falls back to a manual prompt)",
            "Always generate a GitHub Actions workflow",
            "Always generate a GitLab CI pipeline",
            "Always generate an Azure Pipelines pipeline",
            "Always generate a CircleCI config",
            "Always generate a Bitbucket Pipelines config"
          ],
          "default": "auto",
          "description": "Which CI provider to generate a pipeline for."
        },
        "ciPipelineGenerator.matrixVersions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "If non-empty, generate a build matrix across these runtime versions (Node/Python/Go only). Example: [\"18\", \"20\", \"22\"]. Empty means no matrix — just the detected/default version."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  }
}
